{
  "name": "agentledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "generate:api-key": "node -e \"console.log('al_live_' + require('crypto').randomBytes(24).toString('base64url'))\"",
    "generate:cron-secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "setup": "tsx scripts/setup.ts",
    "deploy": "node scripts/deploy.mjs",
    "deploy:web": "node scripts/deploy.mjs --web-only",
    "deploy:ingest": "node scripts/deploy.mjs --ingest-only",
    "submit:ecosystem": "node scripts/submit-ecosystem.mjs",
    "seed:sequences": "node scripts/seed-sequences.mjs",
    "admin": "open http://localhost:3000/admin",
    "publish:packages": "node scripts/publish-packages.mjs",
    "publish:sdk": "node scripts/publish-packages.mjs --sdk",
    "publish:mcp": "node scripts/publish-packages.mjs --mcp"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/prisma-adapter": "^2.7.2",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.1.5",
    "@solana/web3.js": "^1.95.3",
    "autoprefixer": "^10.4.27",
    "bs58": "^6.0.0",
    "next": "14.2.16",
    "next-auth": "^5.0.0-beta.22",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^4.0.0",
    "stripe": "^17.3.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.1",
    "typescript": "^5"
  }
}
