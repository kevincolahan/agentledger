# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/agentledger?schema=public"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (magic link email) ────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM="AgentLedger <noreply@agentledger.io>"

# ─── Anthropic (policy engine) ────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Solana (on-chain anchoring) ──────────────────────────────────────────────
# The platform wallet signs anchor memo transactions
# Fund with ~0.01 SOL — covers thousands of anchoring txs at $0.00025 each
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_ANCHOR_PRIVATE_KEY="[/* byte array */]"  # platform signing wallet

# ─── Helius (tx history for tax engine) ───────────────────────────────────────
HELIUS_API_KEY="..."
HELIUS_RPC_URL="https://mainnet.helius-rpc.com/?api-key=..."

# ─── Cloudflare R2 (report storage) ───────────────────────────────────────────
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="agentledger-reports"
R2_PUBLIC_URL="https://reports.agentledger.io"  # custom domain on R2

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AgentLedger"

# ─── Marketing automation ─────────────────────────────────────────────────────
# Admin email (you) — gates access to /admin
ADMIN_EMAILS="kevin@agentledger.io,kevin@greyleegroup.com"

# SAM.gov API key (free at sam.gov/api — for federal contractor sourcing)
SAM_GOV_API_KEY="DEMO_KEY"

# X/Twitter API Bearer Token (for social monitoring — optional)
TWITTER_BEARER_TOKEN=""

# Hashnode (for auto-publishing blog posts)
HASHNODE_API_KEY=""
HASHNODE_PUBLICATION_ID=""
